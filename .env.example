# Required: OpenRouter API key for GPT-4.1 script generation.
# Get one at https://openrouter.ai/keys. The var is project-namespaced so
# it's clear which app owns the key on multi-project Vercel/Hostinger setups.
KAHAANI_AI_OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Optional: lock CORS to your own domain instead of '*'.
# ALLOWED_ORIGIN=https://your-domain.example.com

# Optional: override the API URL the frontend POSTs to. Leave unset and
# the frontend defaults to /api/generate (the Vercel serverless function
# in api/generate.js). Only set this if you're running a custom backend.
# VITE_API_URL=https://your-backend-host.example.com/webhook/kahaani-generate
